		-
			message: "#^Property Omnipay\\\\Paytr\\\\Message\\\\CompletePurchaseResponse\\:\\:\\$request \\(Omnipay\\\\Paytr\\\\Message\\\\PurchaseRequest\\) does not accept Omnipay\\\\Common\\\\Message\\\\RequestInterface\\.$#"
			count: 1
