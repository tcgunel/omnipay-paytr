			count: 1
			path: src/Message/DeleteCardRequest.php

		-
			message: "#^Method Omnipay\\\\Paytr\\\\Message\\\\DeleteCardResponse\\:\\:getRedirectData\\(\\) should return array but returns null\\.$#"
			count: 1
			path: src/Message/DeleteCardResponse.php

		-
			message: "#^Parameter \\#2 \\$numeric_prefix of function http_build_query expects string, null given\\.$#"
			count: 1
			path: src/Message/InstallmentRateInquiryRequest.php

		-
			message: "#^Method Omnipay\\\\Paytr\\\\Message\\\\InstallmentRateInquiryResponse\\:\\:getRedirectData\\(\\) should return array but returns null\\.$#"
			count: 1
			path: src/Message/InstallmentRateInquiryResponse.php

		-
