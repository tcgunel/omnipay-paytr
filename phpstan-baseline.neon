parameters:
	ignoreErrors:
		-
			message: "#^Access to an undefined property Omnipay\\\\Paytr\\\\Gateway\\:\\:\\$endpoint\\.$#"
			count: 1
			path: src/Gateway.php

		-
			message: "#^PHPDoc tag @param for parameter \\$domElement with type DOMElement\\[Omnipay\\\\Paytr\\\\Helpers\\\\optional\\] is not subtype of native type DOMElement\\|null\\.$#"
			count: 1
			path: src/Helpers/XmlDomConstruct.php

		-
			message: "#^Parameter \\$domElement of method Omnipay\\\\Paytr\\\\Helpers\\\\XmlDomConstruct\\:\\:fromMixed\\(\\) has invalid type Omnipay\\\\Paytr\\\\Helpers\\\\optional\\.$#"
			count: 1
			path: src/Helpers/XmlDomConstruct.php

		-
			message: "#^Call to function is_null\\(\\) with string will always evaluate to false\\.$#"
			count: 1
			path: src/Message/BinLookupRequest.php

		-
			message: "#^Parameter \\#2 \\$numeric_prefix of function http_build_query expects string, null given\\.$#"
			count: 1
			path: src/Message/BinLookupRequest.php

		-
			message: "#^Method Omnipay\\\\Paytr\\\\Message\\\\BinLookupResponse\\:\\:getRedirectData\\(\\) should return array but returns null\\.$#"
			count: 1
